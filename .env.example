# This file documents required configuration keys by name only.

# --- Governed Knowledge Store (PostgreSQL + pgvector) ---
IKIP_DB_HOST=localhost
IKIP_DB_PORT=5432
IKIP_DB_NAME=ikip
IKIP_DB_USER=ikip_app          # least-privilege application role
IKIP_DB_PASSWORD=              # set locally; injected from secrets manager in prod

# --- Object Storage (encrypted) ---
IKIP_OBJECT_ENDPOINT=http://localhost:9000
IKIP_OBJECT_BUCKET=ikip-originals
IKIP_OBJECT_ACCESS_KEY=
IKIP_OBJECT_SECRET_KEY=

# --- Processing Queue (implementation-neutral) ---
IKIP_QUEUE_URL=

# --- Identity Provider (OIDC/SAML) ---
IKIP_OIDC_ISSUER=
IKIP_OIDC_AUDIENCE=
IKIP_OIDC_JWKS_URL=

# --- Asset System of Record (read-only) ---
IKIP_SOR_BASE_URL=
IKIP_SOR_API_KEY=

# --- Model Gateway / Approved Model Provider ---
IKIP_MODEL_PROVIDER=            # e.g. anthropic | local
IKIP_MODEL_NAME=
IKIP_MODEL_API_KEY=
IKIP_MODEL_ALLOWED_ROUTES=      # egress allow-list; empty blocks all
IKIP_MODEL_RETENTION_POLICY=no-retention
IKIP_MODEL_DATA_RESIDENCY=

# --- Observability ---
IKIP_OTEL_ENDPOINT=
IKIP_LOG_LEVEL=INFO

# --- Runnable API pilot (INSECURE; local development only) ---
# Both values are required before caller-controlled X-Dev-* identity headers are accepted.
IKIP_ENV=development
IKIP_DEV_AUTH=0
