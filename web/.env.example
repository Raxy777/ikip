# Copy to .env.local for local overrides. Neither variable is required for the default
# workflow (npm run dev + uvicorn on :8000).

# Only used by `vite.config.ts`'s dev-server proxy (npm run dev). Change this if the API
# doesn't run on the default host/port.
VITE_API_PROXY_TARGET=http://localhost:8000

# Only used in production builds (npm run build / npm run preview), where there is no dev
# proxy. Point this at the API's origin directly. Doing so requires the API to send CORS
# headers for that origin — services/api has none configured, so this needs a backend change
# (e.g. FastAPI's CORSMiddleware) or a same-origin reverse proxy (e.g. nginx) in front of both.
# VITE_API_BASE_URL=https://api.example.com
